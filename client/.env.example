# Local development (Next.js proxy to Express on port 3002)
NEXT_PUBLIC_API_URL=/api
API_PROXY_PORT=3002

# Public site URL (SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudinary (client-side image URLs)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Server-side fetches (sitemap, tour metadata) — optional in dev
# INTERNAL_API_URL=http://127.0.0.1:3002/api

# Vercel production:
# NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api
# NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app
# INTERNAL_API_URL=https://your-backend.vercel.app/api
