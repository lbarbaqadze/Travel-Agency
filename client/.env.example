# Local development
NEXT_PUBLIC_API_URL=/api
API_PROXY_PORT=3002
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Server-side fetches (sitemap, tour metadata) — optional in dev
# INTERNAL_API_URL=http://127.0.0.1:3002/api

# Vercel production (frontend project):
# NEXT_PUBLIC_API_URL=/api
# API_REWRITE_URL=https://your-backend.vercel.app
# INTERNAL_API_URL=https://your-backend.vercel.app/api
# NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
