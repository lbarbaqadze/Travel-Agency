# Server
PORT=3002
NODE_ENV=development

# Database (TiDB Cloud / MySQL)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_DATABASE=
DB_PORT=4000
DB_CONNECTION_LIMIT=3

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES=7d

# Frontend URL (CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUCCESS_URL=http://localhost:3000/my-bookings?session_id={CHECKOUT_SESSION_ID}
CANCEL_URL=http://localhost:3000/my-bookings?checkout=cancelled

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Voyager

# Vercel production overrides:
# FRONTEND_URL=https://your-frontend.vercel.app
# GOOGLE_CALLBACK_URL=https://your-frontend.vercel.app/api/auth/google/callback
# SUCCESS_URL=https://your-frontend.vercel.app/my-bookings?session_id={CHECKOUT_SESSION_ID}
# CANCEL_URL=https://your-frontend.vercel.app/my-bookings?checkout=cancelled
# NODE_ENV=production
